generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id_usuario    Int       @id @default(autoincrement())
  nome          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(100)
  senha         String    @db.VarChar(255)
  data_cadastro DateTime  @default(now())
  cpf           String    @unique @db.Char(11)
  telefone      String?   @unique @db.VarChar(11)
  foto_perfil   String?   @db.VarChar(255)

  anuncios  Anuncio[]
  mensagens Mensagem[]
  chats Chat[]

  role Role @default(USER)

  @@map("usuario")
}

model Imagem {
  id_imagem   Int    @id @default(autoincrement())
  url_caminho String @db.VarChar(255)

  id_anuncio Int?

  anuncio Anuncio? @relation(fields: [id_anuncio], references: [id_anuncio], onDelete: Cascade)

  @@map("imagem")
}

model Anuncio {
  id_anuncio   Int           @id @default(autoincrement())
  titulo       String        @db.VarChar(100)
  descricao    String        @db.Text
  preco        Decimal       @db.Decimal(10, 2)
  data_criacao DateTime      @default(now())
  condicao     Condicao
  marca        String?       @db.VarChar(100)
  status       StatusAnuncio @default(ATIVO)
  categoria    Categoria

  id_usuario   Int

  usuario   Usuario   @relation(fields: [id_usuario], references: [id_usuario])
  imagens   Imagem[]
  chats     Chat[]

  @@map("anuncio")
}

model Chat {
  id_chat      Int      @id @default(autoincrement())
  data_criacao DateTime @default(now())

  id_anuncio Int
  id_usuario Int

  anuncio   Anuncio    @relation(fields: [id_anuncio], references: [id_anuncio], onDelete: Cascade)
  usuario   Usuario    @relation(fields: [id_usuario], references: [id_usuario])
  mensagens Mensagem[]

  @@map("chat")
}

model Mensagem {
  id_mensagem Int      @id @default(autoincrement())
  texto       String   @db.Text
  data_envio  DateTime @default(now())
  lida        Boolean  @default(false)

  id_usuario Int
  id_chat    Int

  usuario Usuario @relation(fields: [id_usuario], references: [id_usuario])
  chat    Chat    @relation(fields: [id_chat], references: [id_chat], onDelete: Cascade)

  @@map("mensagem")
}

enum Condicao {
  NOVO
  USADO
}

enum StatusAnuncio {
  ATIVO
  INATIVO
  TROCADO
}

enum Role{
  USER
  ADMIN
}

enum Categoria {
  CPU
  GPU
  PLACA_MAE
  RAM
  FONTE
  GABINETE
  ARMAZENAMENTO
  COOLER
  MONITOR
  TECLADO
  MOUSE
  HEADSET
}